{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoWise",
  "version": "0.1.0",
  "identifier": "com.echowise.app",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EchoWise",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Education",
    "shortDescription": "AI English speaking & listening tutor",
    "longDescription": "Open-source cross-platform AI tutor for English speaking and listening practice.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  }
}
