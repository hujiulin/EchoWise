{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-app-meta-recursive"
  ]
}
